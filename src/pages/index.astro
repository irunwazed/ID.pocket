---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ID Flow - Dashboard">
  <main class="min-h-screen flex flex-col items-center justify-center p-8 gap-8">
    <div class="text-center mb-4">
      <h1 class="text-6xl md:text-7xl font-bold text-transparent bg-clip-text bg-linear-to-r from-indigo-500 via-purple-500 to-pink-500 mb-6" style="font-family: 'Quicksand', sans-serif;">
        ID Flow
      </h1>
      <p class="text-gray-500 text-xl md:text-2xl font-normal" style="font-family: 'Quicksand', sans-serif;">
        Flow your money, grow your life.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6 w-full max-w-6xl">
      <a
        href="/users"
        class="group p-6 bg-white/80 backdrop-blur-sm rounded-2xl shadow-lg hover:shadow-2xl transition-all hover:-translate-y-2 border border-gray-100"
      >
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 bg-linear-to-br from-indigo-100 to-purple-100 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
            <span class="text-2xl">👥</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-800" style="font-family: 'Quicksand', sans-serif;">Users</h3>
            <p class="text-sm text-gray-500">Manage users</p>
          </div>
        </div>
      </a>

      <a
        href="/transactions"
        class="group p-6 bg-white/80 backdrop-blur-sm rounded-2xl shadow-lg hover:shadow-2xl transition-all hover:-translate-y-2 border border-gray-100"
      >
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 bg-linear-to-br from-green-100 to-emerald-100 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
            <span class="text-2xl">💰</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-800" style="font-family: 'Quicksand', sans-serif;">Transactions</h3>
            <p class="text-sm text-gray-500">Manage transactions</p>
          </div>
        </div>
      </a>

      <a
        href="/types"
        class="group p-6 bg-white/80 backdrop-blur-sm rounded-2xl shadow-lg hover:shadow-2xl transition-all hover:-translate-y-2 border border-gray-100"
      >
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 bg-linear-to-br from-purple-100 to-pink-100 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
            <span class="text-2xl">🏷️</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-800" style="font-family: 'Quicksand', sans-serif;">Types</h3>
            <p class="text-sm text-gray-500">Manage transaction types</p>
          </div>
        </div>
      </a>

      <a
        href="/stats"
        class="group p-6 bg-white/80 backdrop-blur-sm rounded-2xl shadow-lg hover:shadow-2xl transition-all hover:-translate-y-2 border border-gray-100"
      >
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 bg-linear-to-br from-yellow-100 to-orange-100 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
            <span class="text-2xl">📊</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-800" style="font-family: 'Quicksand', sans-serif;">Statistics</h3>
            <p class="text-sm text-gray-500">View statistics</p>
          </div>
        </div>
      </a>

      <a
        href="/recap"
        class="group p-6 bg-white/80 backdrop-blur-sm rounded-2xl shadow-lg hover:shadow-2xl transition-all hover:-translate-y-2 border border-gray-100"
      >
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 bg-linear-to-br from-rose-100 to-red-100 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
            <span class="text-2xl">📋</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-800" style="font-family: 'Quicksand', sans-serif;">Recap</h3>
            <p class="text-sm text-gray-500">View yearly recap</p>
          </div>
        </div>
      </a>
    </div>
  </main>
</Layout>
